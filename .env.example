OPENAI_API_KEY=sk-your-api-key-here
# GitHub API (Render 배포 시 권장) — 없으면 시간당 ~60회/IP 한도, 클라우드에서 금방 소진
# Personal Access Token(classic), 공개 레포 읽기만이면 스코프 없어도 됨
GITHUB_TOKEN=

